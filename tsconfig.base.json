{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@orbi/core": [
        "packages/core/index.ts"
      ],
      "@orbi/tokens": [
        "packages/tokens/index.ts"
      ],
      "@orbi/react": [
        "packages/react/index.ts"
      ],
      "@/*": [
        "packages/docs/src/*"
      ]
    }
  }
}