{
  "name": "orbi-ui",
  "version": "0.1.1-alpha",
  "description": "Design system and component framework for React",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build",
    "build:core": "tsc --project packages/core/tsconfig.json",
    "build:tokens": "tsc --project packages/tokens/tsconfig.json",
    "build:react": "tsc --project packages/react/tsconfig.json",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:coverage": "vitest --coverage --run",
    "test:types": "vitest --run packages/react/__contracts__/api.test-d.ts",
    "check:size": "node scripts/check-bundle-size.js",
    "type-check": "pnpm exec tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "18.2.43",
    "@types/react-dom": "18.2.17",
    "@vitejs/plugin-react": "^5.1.4",
    "axe-core": "^4.8.3",
    "esbuild": "^0.18.19",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "terser": "^5.17.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
